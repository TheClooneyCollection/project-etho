<nav class="month-pagination{% if navClass %} {{ navClass }}{% endif %}" aria-label="{{ navAriaLabel or 'Month pagination' }}">
  {% if pagination.href.previous %}
    <a
      class="month-pagination__link js-month-pagination-prev"
      data-base-href="{{ pagination.href.previous }}"
      data-month="{{ videosByMonth[pagination.pageNumber - 1].key }}"
      href="{{ pagination.href.previous }}"
      data-umami-event="nav-prev-month"
    >
      ←
      <span
        class="js-locale-month"
        data-year="{{ videosByMonth[pagination.pageNumber - 1].year }}"
        data-month="{{ videosByMonth[pagination.pageNumber - 1].month }}"
      >{{ videosByMonth[pagination.pageNumber - 1].key }}</span>
    </a>
  {% endif %}

  {% if pagination.href.next %}
    <a
      class="month-pagination__link month-pagination__link--next js-month-pagination-next"
      data-base-href="{{ pagination.href.next }}"
      data-month="{{ videosByMonth[pagination.pageNumber + 1].key }}"
      href="{{ pagination.href.next }}"
      data-umami-event="nav-next-month"
    >
      <span
        class="js-locale-month"
        data-year="{{ videosByMonth[pagination.pageNumber + 1].year }}"
        data-month="{{ videosByMonth[pagination.pageNumber + 1].month }}"
      >{{ videosByMonth[pagination.pageNumber + 1].key }}</span>
      →
    </a>
  {% endif %}
</nav>
