<div class="month-controls">
  <div class="month-controls__buttons">
    <a class="month-controls__button" href="{{ latestHref }}">Latest</a>
    <a class="month-controls__button" href="{{ oldestHref }}">Earliest</a>
  </div>

  <div class="month-picker js-month-picker">
    <label class="month-picker__label" for="month-picker-input">Jump to month</label>
    <input
      id="month-picker-input"
      class="month-picker__input js-month-picker-input"
      type="month"
      value="{{ monthPage.key }}"
      min="{{ oldestPage.key }}"
      max="{{ latestPage.key }}"
    >
    <button class="month-picker__go js-month-picker-go" type="button">Go</button>
    <div class="month-picker__routes" hidden>
      {% for entry in videosByMonth %}
        {% set monthHref = "/" %}
        {% if not loop.first %}
          {% set monthHref = "/" ~ entry.key ~ "/" %}
        {% endif %}
        <a
          data-month="{{ entry.key }}"
          data-base-href="{{ monthHref }}"
          href="{{ monthHref }}"
        ></a>
      {% endfor %}
    </div>
  </div>
</div>

<div class="creator-filter js-creator-filter" data-current-month="{{ monthPage.key }}">
  <details class="creator-filter__details">
    <summary class="creator-filter__summary">Filter by creator</summary>
    <div class="creator-filter__content">
      <p class="creator-filter__active js-creator-active" hidden></p>
      <div class="creator-filter__actions">
        <button class="creator-filter__clear js-creator-clear" type="button" hidden>Clear filter</button>
      </div>
      <ul class="creator-filter__list">
        {% for creator in monthCreatorIndex[monthPage.key] or [] %}
          <li>
            <div class="creator-filter__item-row">
              <a
                class="creator-filter__option js-creator-option"
                data-creator-key="{{ creator.key }}"
                data-creator-name="{{ creator.name }}"
                data-month-count="{{ creator.monthCount }}"
                href="?creator={{ creator.key }}"
              >{{ creator.name }} ({{ creator.monthCount }})</a>
              <a class="ui-link-button creator-filter__view-all" href="/creator/{{ creator.pathKey }}/">View all ({{ creator.totalCount }})</a>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </details>
  <p class="creator-filter__empty js-creator-empty" hidden>No videos for this creator in this month.</p>
</div>
